# ═══════════════════════════════════════════════════════════════
# Tourism Make Easy — Development Environment
# ═══════════════════════════════════════════════════════════════

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_USER=tme_admin
POSTGRES_PASSWORD=tme_secret
POSTGRES_HOST=tme-postgres
POSTGRES_PORT=5432

# ── Database Names ────────────────────────────────────────────
CENTRAL_DB=central_db
INVENTORY_DB=inventory_db
RESERVATION_DB=reservation_db
RESORT_DB=resort_db

# ── Service Ports ─────────────────────────────────────────────
CENTRAL_SERVICE_PORT=8080
INVENTORY_SERVICE_PORT=8081
RESERVATION_SERVICE_PORT=8082
RESORT_SERVICE_PORT=8083

# ── JPA / Hibernate ──────────────────────────────────────────
JPA_DDL_AUTO=update
JPA_SHOW_SQL=false

# ── Spring ────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=docker
